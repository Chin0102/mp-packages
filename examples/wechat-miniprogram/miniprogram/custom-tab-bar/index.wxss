:host {
  --tab-color: #64748b;
  --tab-selected-color: #2563eb;
}

.custom-tab-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1000;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(148, 163, 184, 0.24);
  box-shadow: 0 -12rpx 40rpx rgba(15, 23, 42, 0.08);
}

.custom-tab-bar__content {
  display: flex;
  height: 112rpx;
}

.custom-tab-bar__safe-area {
  height: env(safe-area-inset-bottom);
}

.tab-item {
  position: relative;
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--tab-color);
}

.tab-item__indicator {
  position: absolute;
  top: 0;
  width: 48rpx;
  height: 6rpx;
  background: transparent;
  border-radius: 0 0 999rpx 999rpx;
}

.tab-item--selected {
  color: var(--tab-selected-color);
}

.tab-item--selected .tab-item__indicator {
  background: var(--tab-selected-color);
}

.tab-item__icon {
  box-sizing: border-box;
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 4rpx;
}

.tab-item__icon--components {
  display: grid;
  grid-template-columns: repeat(2, 14rpx);
  grid-template-rows: repeat(2, 14rpx);
  gap: 5rpx;
  padding: 3rpx;
}

.components-dot {
  box-sizing: border-box;
  border: 3rpx solid currentColor;
  border-radius: 5rpx;
}

.tab-item__icon--runtime {
  padding: 7rpx 5rpx;
  border: 3rpx solid currentColor;
  border-radius: 8rpx;
}

.runtime-line {
  width: 22rpx;
  height: 3rpx;
  margin-bottom: 5rpx;
  background: currentColor;
  border-radius: 999rpx;
}

.runtime-line--short {
  width: 13rpx;
}

.tab-item__text {
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.2;
}
