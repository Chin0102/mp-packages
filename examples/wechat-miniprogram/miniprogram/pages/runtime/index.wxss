.runtime-navigation__content {
  padding-right: 32rpx;
}

.runtime-navigation__background {
  box-shadow: 0 1rpx 0 rgba(148, 163, 184, 0.2);
}

.navigation-background {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.95);
}

.navigation-title {
  font-size: 32rpx;
  font-weight: 700;
}

.runtime-summary {
  margin: 12rpx 0 28rpx;
  padding: 36rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1d4ed8, #0f766e);
  border-radius: 28rpx;
}

.runtime-summary__label,
.runtime-summary__value,
.runtime-summary__description,
.runtime-summary__system {
  display: block;
}

.runtime-summary__label {
  margin-bottom: 8rpx;
  font-size: 22rpx;
  opacity: 0.78;
}

.runtime-summary__value {
  margin-bottom: 20rpx;
  font-size: 44rpx;
  font-weight: 800;
}

.runtime-summary__description {
  font-size: 26rpx;
  line-height: 1.6;
  opacity: 0.86;
}

.runtime-summary__system {
  margin-top: 20rpx;
  padding-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.5;
  border-top: 1rpx solid rgba(255, 255, 255, 0.24);
  opacity: 0.78;
}

.metric {
  display: block;
  margin: 12rpx 0;
  color: #1d4ed8;
  font-size: 72rpx;
  font-weight: 800;
}

.api-result {
  display: block;
  box-sizing: border-box;
  width: 100%;
  margin-top: 24rpx;
  padding: 20rpx;
  overflow-wrap: anywhere;
  color: #cbd5e1;
  font-family: monospace;
  font-size: 22rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  background: #0f172a;
  border-radius: 16rpx;
}

.storage-values {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  color: #1e40af;
  font-size: 26rpx;
  background: #eff6ff;
  border-radius: 16rpx;
}

.auth-result {
  display: block;
  margin-top: 24rpx;
  color: #0f766e;
  font-size: 24rpx;
  line-height: 1.6;
}

.toolbox-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #ffffff, #eff6ff);
}

.toolbox-entry__description {
  display: block;
  max-width: 540rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.6;
}

.toolbox-entry__arrow {
  color: #2563eb;
  font-size: 48rpx;
}
