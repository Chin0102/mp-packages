<mp-navigation fixed placeholder background-class="runtime-navigation__background" content-class="runtime-navigation__content">
  <view slot="background" class="navigation-background"></view>
  <text class="navigation-title">运行时验证</text>
</mp-navigation>

<view class="page tab-page runtime-page">
  <view class="runtime-summary">
    <text class="runtime-summary__label">当前环境</text>
    <text class="runtime-summary__value">{{environment}}</text>
    <text class="runtime-summary__description">页面由 definePage 管理生命周期和清理函数。</text>
    <text class="runtime-summary__system">{{systemSummary}}</text>
  </view>

  <view class="section">
    <text class="section__title">Store + 持久化</text>
    <text class="metric">{{demo.count}}</text>
    <text class="section__description">最近更新：{{demo.updatedAt}}</text>
    <view class="button-row">
      <button class="button" bindtap="increment">增加</button>
      <button class="button button--secondary" bindtap="resetStore">重置</button>
    </view>
  </view>

  <view class="section">
    <text class="section__title">Adapter Storage</text>
    <view class="storage-values">
      <text>主题：{{preferences.theme}}</text>
      <text>音量：{{preferences.volume}}</text>
    </view>
    <text class="section__description">订阅记录：{{storageHistory}}</text>
    <view class="button-row">
      <button class="button button--secondary" bindtap="toggleTheme">切换主题</button>
      <button class="button button--secondary" bindtap="increaseVolume">音量 +10</button>
      <button class="button button--ghost" bindtap="flushPreferences">立即写入</button>
      <button class="button button--ghost" bindtap="reloadPreferences">重新读取</button>
      <button class="button button--ghost" bindtap="removePreferences">删除存储</button>
    </view>
  </view>

  <view class="section">
    <text class="section__title">js-common Event</text>
    <text class="section__description">{{eventMessage}}</text>
    <button class="button button--secondary" bindtap="emitEvent">发送事件</button>
  </view>

  <view class="section">
    <text class="section__title">Auth + API Client</text>
    <text class="section__description">本地 mock transport 可验证并发登录合并、Authorization 注入和 401 自动续期，全程不发送外网请求。</text>
    <view class="button-row">
      <button class="button" loading="{{apiLoading}}" disabled="{{apiLoading}}" bindtap="callApi">普通请求</button>
      <button class="button button--secondary" disabled="{{apiLoading}}" bindtap="runConcurrentAuth">并发登录</button>
      <button class="button button--secondary" disabled="{{apiLoading}}" bindtap="runAuthRenewal">401 续期</button>
    </view>
    <text class="auth-result">{{authResult}}</text>
    <text class="api-result">{{apiResult}}</text>
  </view>

  <view class="section toolbox-entry" bindtap="openToolbox">
    <view>
      <text class="section__title">js-common 工具实验室</text>
      <text class="toolbox-entry__description">进入非 tab 详情页，体验请求合并、debounce、throttle 和 URL 工具。</text>
    </view>
    <text class="toolbox-entry__arrow">→</text>
  </view>

  <mp-page-bottom min="24" append="24"></mp-page-bottom>
</view>
