.demo-navigation__background {
  backdrop-filter: blur(16rpx);
}

.demo-navigation__content {
  padding-right: 32rpx;
}

.navigation-background {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.92);
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.25);
}

.navigation-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
}

.hero {
  padding: 36rpx 8rpx 44rpx;
}

.hero__eyebrow,
.hero__title,
.hero__description {
  display: block;
}

.hero__eyebrow {
  margin-bottom: 12rpx;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero__title {
  margin-bottom: 16rpx;
  color: #0f172a;
  font-size: 52rpx;
  font-weight: 800;
}

.hero__description {
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.6;
}

.status-card__value {
  color: #2563eb;
  font-size: 28rpx;
}

.countdown-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #eff6ff;
  border-radius: 18rpx;
}

.countdown-prefix {
  margin-right: 16rpx;
  color: #64748b;
  font-size: 24rpx;
}

.demo-countdown__text {
  color: #1d4ed8;
  font-size: 40rpx;
  font-weight: 800;
}

.countdown-status {
  color: #64748b;
  font-size: 24rpx;
}

.bottom-label {
  display: block;
  padding: 20rpx 0;
  color: #94a3b8;
  font-size: 24rpx;
  text-align: center;
}

.demo-popup {
  box-shadow: 0 -20rpx 60rpx rgba(15, 23, 42, 0.16);
}

.popup-content {
  box-sizing: border-box;
  padding: 40rpx 32rpx 0;
}

.popup-content__title,
.popup-content__description {
  display: block;
}

.popup-content__title {
  margin-bottom: 16rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.popup-content__description {
  margin-bottom: 32rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

.demo-dialog-title {
  color: #1d4ed8;
}
