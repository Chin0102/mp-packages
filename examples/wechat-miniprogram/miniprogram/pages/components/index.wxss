.demo-navigation__background {
  backdrop-filter: blur(16rpx);
}

.demo-navigation__content {
  padding-right: 32rpx;
}

.navigation-background {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.92);
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.25);
}

.navigation-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
}

.hero {
  padding: 36rpx 8rpx 44rpx;
}

.hero__eyebrow,
.hero__title,
.hero__description {
  display: block;
}

.hero__eyebrow {
  margin-bottom: 12rpx;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero__title {
  margin-bottom: 16rpx;
  color: #0f172a;
  font-size: 52rpx;
  font-weight: 800;
}

.hero__description {
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.6;
}

.status-card__value {
  color: #2563eb;
  font-size: 28rpx;
}

.countdown-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #eff6ff;
  border-radius: 18rpx;
}

.countdown-prefix {
  margin-right: 16rpx;
  color: #64748b;
  font-size: 24rpx;
}

.demo-countdown__text {
  color: #1d4ed8;
  font-size: 40rpx;
  font-weight: 800;
}

.countdown-status {
  display: block;
  color: #64748b;
  font-size: 24rpx;
}

.countdown-meta {
  text-align: right;
}

.countdown-tick {
  display: block;
  margin-top: 6rpx;
  color: #2563eb;
  font-size: 22rpx;
}

.position-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.position-grid .button {
  min-width: 0;
  width: 100%;
  padding-right: 12rpx;
  padding-left: 12rpx;
}

.bottom-label {
  display: block;
  padding: 20rpx 0;
  color: #94a3b8;
  font-size: 24rpx;
  text-align: center;
}

.demo-popup {
  box-shadow: 0 -20rpx 60rpx rgba(15, 23, 42, 0.16);
}

.popup-content {
  box-sizing: border-box;
  width: 680rpx;
  padding: 40rpx 32rpx;
}

.popup-content--left,
.popup-content--right {
  width: 560rpx;
  height: 100vh;
  padding-top: 160rpx;
}

.popup-content--center {
  width: 600rpx;
}

.popup-content__eyebrow,
.popup-content__title,
.popup-content__description {
  display: block;
}

.popup-content__eyebrow {
  margin-bottom: 10rpx;
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.popup-content__title {
  margin-bottom: 16rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.popup-content__description {
  margin-bottom: 32rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

.demo-dialog-title {
  color: #1d4ed8;
}

.custom-dialog-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.custom-dialog-header__badge {
  padding: 6rpx 12rpx;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  background: #0f766e;
  border-radius: 999rpx;
}

.custom-dialog-header__title {
  font-size: 32rpx;
  font-weight: 700;
}

.custom-dialog-content {
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.7;
}

.custom-dialog-footer {
  padding: 0 32rpx 32rpx;
}

.custom-dialog-footer .button {
  width: 100%;
}
