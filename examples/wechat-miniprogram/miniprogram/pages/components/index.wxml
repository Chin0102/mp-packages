<mp-navigation fixed placeholder background-class="demo-navigation__background" content-class="demo-navigation__content">
  <view slot="background" class="navigation-background"></view>
  <text class="navigation-title">mp-components</text>
</mp-navigation>

<view class="page tab-page">
  <view class="hero">
    <text class="hero__eyebrow">LOCAL PACKAGE PLAYGROUND</text>
    <text class="hero__title">原生组件验证</text>
    <text class="hero__description">集中检查安全区、弹层交互和外部样式覆盖。</text>
  </view>

  <view class="section">
    <text class="section__title">Countdown</text>
    <text class="section__description">按真实截止时间计算，页面计时器发生延迟时也不会累计漂移。</text>
    <view class="countdown-row">
      <mp-countdown
        id="demo-countdown"
        duration="{{countdownDuration}}"
        target-time="{{countdownTargetTime}}"
        paused="{{countdownPaused}}"
        pause-on-hide
        format="mm:ss"
        text-class="demo-countdown__text"
        bindtick="handleCountdownTick"
        bindfinish="handleCountdownFinish"
      >
        <text slot="prefix" class="countdown-prefix">剩余</text>
      </mp-countdown>
      <view class="countdown-meta">
        <text class="countdown-status">{{countdownStatus}}</text>
        <text class="countdown-tick">{{countdownTick}}</text>
      </view>
    </view>
    <view class="button-row">
      <button class="button button--secondary" bindtap="toggleCountdown">{{countdownPaused ? '继续' : '暂停'}}</button>
      <button class="button button--secondary" bindtap="restartCountdown">重新开始</button>
      <button class="button button--ghost" bindtap="switchCountdownMode">切换为{{countdownMode === 'duration' ? '绝对时间' : '时长'}}</button>
    </view>
  </view>

  <view class="section">
    <text class="section__title">Overlay</text>
    <text class="section__description">全屏遮罩、滚动锁定及点击关闭事件。</text>
    <button class="button" bindtap="openOverlay">打开遮罩</button>
  </view>

  <view class="section">
    <text class="section__title">Popup</text>
    <text class="section__description">验证 center、top、right、bottom 和 left 五种位置及遮罩关闭事件。</text>
    <view class="position-grid">
      <button class="button button--secondary" data-position="top" bindtap="openPopup">顶部</button>
      <button class="button button--secondary" data-position="right" bindtap="openPopup">右侧</button>
      <button class="button" data-position="center" bindtap="openPopup">居中</button>
      <button class="button button--secondary" data-position="bottom" bindtap="openPopup">底部</button>
      <button class="button button--secondary" data-position="left" bindtap="openPopup">左侧</button>
    </view>
  </view>

  <view class="section">
    <text class="section__title">Dialog</text>
    <text class="section__description">对比标准动作区和使用 header/footer slot 的完全自定义内容。</text>
    <view class="button-row">
      <button class="button" data-mode="standard" bindtap="openDialog">标准对话框</button>
      <button class="button button--secondary" data-mode="custom" bindtap="openDialog">自定义插槽</button>
    </view>
  </view>

  <view class="section status-card">
    <text class="section__title">最近操作</text>
    <text class="status-card__value">{{lastAction}}</text>
  </view>

  <mp-page-bottom min="24" append="24" custom-class="demo-page-bottom">
    <text class="bottom-label">安全区占位上方内容</text>
  </mp-page-bottom>
</view>

<mp-overlay
  visible="{{overlayVisible}}"
  opacity="{{0.72}}"
  background-color="#0f172a"
  close-on-tap
  bindclose="closeOverlay"
></mp-overlay>

<mp-popup
  visible="{{popupVisible}}"
  position="{{popupPosition}}"
  round
  close-on-overlay
  content-class="demo-popup"
  bindclose="closePopup"
>
  <view class="popup-content popup-content--{{popupPosition}}">
    <text class="popup-content__eyebrow">{{popupPosition}}</text>
    <text class="popup-content__title">五方向弹层</text>
    <text class="popup-content__description">容器位置和动画由组件处理，业务页面只负责内容与状态。</text>
    <button class="button" bindtap="closePopup">完成</button>
    <mp-page-bottom min="20"></mp-page-bottom>
  </view>
</mp-popup>

<mp-dialog
  visible="{{dialogVisible}}"
  title="{{dialogCustom ? '' : '确认操作'}}"
  content="{{dialogCustom ? '' : '这是一个不包含业务配色的通用对话框。'}}"
  close-on-overlay
  show-actions="{{!dialogCustom}}"
  title-class="demo-dialog-title"
  bindclose="closeDialog"
>
  <view wx:if="{{dialogCustom}}" slot="header" class="custom-dialog-header">
    <text class="custom-dialog-header__badge">SLOT</text>
    <text class="custom-dialog-header__title">自定义标题区域</text>
  </view>
  <view wx:if="{{dialogCustom}}" class="custom-dialog-content">默认内容 slot 可以放入任意业务视图。</view>
  <view wx:if="{{dialogCustom}}" slot="footer" class="custom-dialog-footer">
    <button class="button" bindtap="closeDialog">知道了</button>
  </view>
</mp-dialog>
