{
  "name": "@chin0102/mp-core",
  "version": "0.1.0",
  "description": "Core utilities for Node.js and WeChat Mini Program projects.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./src/index.js",
  "miniprogram": "dist",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev:push": "npm run build && yalc push",
    "build": "node scripts/build.js",
    "check": "npm run build && node --check src/index.js && node --check dist/index.js",
    "test": "node --test",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "wechat",
    "miniprogram",
    "framework",
    "esm"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@chin0102/mp-adapter": "^0.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "prettier": "3.9.5"
  }
}
